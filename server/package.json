{
  "name": "rounds-server",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier . --write",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.24.1",
    "@prisma/client": "^6.2.1",
    "playwright": "^1.49.1",
    "@fastify/cors": "^10.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "prisma": "^6.2.1",
    "@types/node": "^22.13.1",
    "@types/node-cron": "^3.0.11"
  }
}
